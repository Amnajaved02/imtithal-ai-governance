# Server-side secrets — set these in Vercel → Project Settings → Environment Variables.
# Never commit real values.

# Anthropic API key, used by /api/public/generate-report for the executive summary.
ANTHROPIC_API_KEY=

# n8n PRODUCTION webhook URL (the /webhook/ one, not /webhook-test/),
# used by /api/public/deep-analysis to reach the agent workflow.
N8N_WEBHOOK_URL=

# Supabase client values. These are public by design (the publishable/anon key is
# meant to be visible to browsers), but they are kept out of git for cleanliness.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
